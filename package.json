{
  "name": "mazhavilcostumes-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Mazhavil Costumes - Costumes Rental Business Monorepo",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "start": "turbo start",
    "lint": "turbo lint",
    "check:admin": "pnpm --filter admin lint && pnpm --filter admin build",
    "check:mobile": "cd apps/mobile && flutter analyze --no-pub",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@supabase/supabase-js": "^2.105.4",
    "@types/node": "^20",
    "prettier": "^3.4.2",
    "supabase": "^2.95.3",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20.9.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
